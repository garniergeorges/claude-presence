# Required (only relevant for the Caddy variant): public domain that
# Caddy will request a Let's Encrypt certificate for.
# CADDY_DOMAIN=claude-presence.example.com

# Optional. Override the port mapped on the host. Default: 3471.
# CP_PORT=3471

# Optional. Override the log level. Default: info. One of: debug | info | warn | error
# LOG_LEVEL=info
