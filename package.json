{
  "name": "claude-presence",
  "version": "0.2.0",
  "description": "Minimal MCP server for inter-session coordination between parallel Claude Code instances: presence registry, resource locks, broadcast inbox.",
  "type": "module",
  "bin": {
    "claude-presence": "dist/cli/index.js",
    "claude-presence-mcp": "dist/index.js",
    "claude-presence-server": "dist/server/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "hooks",
    "examples",
    "commands",
    "assets",
    "README.md",
    "README.fr.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "coordination",
    "presence",
    "multi-session",
    "lock",
    "inter-process"
  ],
  "author": "Georges Garnier (https://github.com/garniergeorges)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garniergeorges/claude-presence.git"
  },
  "bugs": {
    "url": "https://github.com/garniergeorges/claude-presence/issues"
  },
  "homepage": "https://github.com/garniergeorges/claude-presence#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
